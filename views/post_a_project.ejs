<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="css/post_a_project.css" />
		<script src="string_injection_block.js"></script>
		<title>Post a project</title>
	</head>

	<% if (user !=null) { %>
    	<%- include("partials/userheader") %>
	<% } else { %>
		<%- include("partials/header") %>
	<% } %>
	<body>
		

		<h1>Categories</h1>

		<div class="category-grid">
			<a href="/post/3D Printing" class="category-card">
				<img src="/images/3D.jpg" alt="3D Printing">
				<div class="card-content">
					<h3>3D Printing</h3>
					<p>Create custom 3D printed objects and prototypes.</p>
				</div>
			</a>
			<a href="/post/Poster" class="category-card">
				<img src="/images/posters.jpg" alt="Poster">
				<div class="card-content">
					<h3>Poster</h3>
					<p>Design and print custom posters for events and decor.</p>
				</div>
			</a>
			<a href="/post/Art" class="category-card">
				<img src="/images/art.jpg" alt="Art">
				<div class="card-content">
					<h3>Art</h3>
					<p>Commission original artwork and creative pieces.</p>
				</div>
			</a>
			<a href="/post/Wood" class="category-card">
				<img src="/images/wood.jpg" alt="Wood">
				<div class="card-content">
					<h3>Wood</h3>
					<p>Order custom woodworking and wooden crafts.</p>
				</div>
			</a>
			<a href="/post/Stationary" class="category-card">
				<img src="/images/stationary.jpg" alt="Stationary">
				<div class="card-content">
					<h3>Stationary</h3>
					<p>Customize personalized stationery and paper goods.</p>
				</div>
			</a>
			<a href="/post/Fabric" class="category-card">
				<img src="/images/fabric.jpg" alt="Fabric">
				<div class="card-content">
					<h3>Fabric</h3>
					<p>Order custom fabric and other textile arts.</p>
				</div>
			</a>
		</div>
	</body>
</html>
