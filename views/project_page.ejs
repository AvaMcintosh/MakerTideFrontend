<!doctype html>
<html lang="en">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="stylesheet" href="/css/project_page.css" />
	<title>Homepage</title>
</head>

<% if (user !=null) { %>
	<%- include("partials/userheader") %>
		<% } else { %>
			<%- include("partials/header") %>
				<% } %>

					<body>

						<div class="projects-body">

							<% projects.forEach(project=> { %>
								<div class="project-card" onclick="window.location.href='/projects/<%= project.id %>'">

									<img src="<%= project.image %>" class="project-image" />

									<div class="project-content">
										<h4>
											<%= project.title %>
										</h4>
										<p><strong>Category:</strong>
											<%= project.category %>
										</p>
										<p><strong>Location:</strong>
											<%= project.location %>
										</p>
										<p><strong>Deadline:</strong>
											<%= project.deadline %>
										</p>
										<p><strong>Quantity:</strong>
											<%= project.quantity %>
										</p>
									</div>

									<button
										onclick="event.stopPropagation(); this.nextElementSibling.style.display='block';">
										Make Bid
									</button>

									<form action="/submitBid" method="POST" style="display:none;"
										onclick="event.stopPropagation();">
										<input type="hidden" name="projectId" value="<%= project.id %>" />
										<input type="number" name="bidAmount" placeholder="Enter bid amount" required />
										<input type="text" name="message" placeholder="Enter message" required />
										<button type="submit">Submit Bid</button>
									</form>

								</div>
								<% }) %>

						</div>



						<div class="projects-search-box">
							<h3>Filter Projects</h3>

							<input type="text" placeholder="Search projects..." class="search-input" />

							<form method="GET" action="/projects">
								<div class="category-filters">

									<label>
										<input type="checkbox" name="category" value="3D Printing" />
										3D Printing
									</label>

									<label>
										<input type="checkbox" name="category" value="Fabric / Embroidery" />
										Fabric / Embroidery
									</label>

									<label>
										<input type="checkbox" name="category" value="Posters" />
										Posters
									</label>

									<label>
										<input type="checkbox" name="category" value="Metal" />
										Metal
									</label>

									<label>
										<input type="checkbox" name="category" value="Wood" />
										Wood
									</label>

									<label>
										<input type="checkbox" name="category" value="Art" />
										Art
									</label>

									<label>
										<input type="checkbox" name="category" value="Stationary" />
										Stationary
									</label>

									<label>
										<input type="checkbox" name="category" value="Other" />
										Other
									</label>

								</div>

								<button type="submit">Filter</button>
							</form>
						</div>



					</body>

</html>

<% projects.forEach(project=> { %>
	<div class="project-card">
		<h3>
			<%= project.title %>
		</h3>
		<p>
			<%= project.category %>
		</p>
	</div>
	<% }) %>
